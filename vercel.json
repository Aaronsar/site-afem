{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "site-afem.vercel.app" }],
      "destination": "https://www.afem-edu.fr/:path",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/articles/:path*", "destination": "/articles/_template" },
    { "source": "/prepas-medecine/:path*", "destination": "/prepas-medecine/_template" },
    { "source": "/facultes/:path*", "destination": "/facultes/_template" }
  ]
}
